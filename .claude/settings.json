{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONIOENCODING=utf-8 python c:/freee/scripts/session_start.py"
          },
          {
            "type": "command",
            "command": "PYTHONIOENCODING=utf-8 python c:/freee/scripts/backup_journals.py"
          },
          {
            "type": "command",
            "command": "python c:/freee/scripts/backup_logs.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__freee-mcp__freee_api_*",
        "hooks": [
          {
            "type": "command",
            "command": "python c:/freee/scripts/log_freee_op.py"
          },
          {
            "type": "command",
            "command": "python c:/freee/scripts/backup_logs.py"
          }
        ]
      }
    ]
  }
}
